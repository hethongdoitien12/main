# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/mt_economy

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=your-very-long-random-secret-here

# ─── Payment Gateways ─────────────────────────────────────────────────────────
# MoMo (sandbox keys from MoMo Developer Portal)
MOMO_PARTNER_CODE=MOMO_SANDBOX
MOMO_ACCESS_KEY=your-momo-access-key
MOMO_SECRET_KEY=your-momo-secret-key
MOMO_REDIRECT_URL=https://your-app.replit.app/payment/result
MOMO_IPN_URL=https://your-app.replit.app/api/wallet/deposit/momo-ipn

# ZaloPay (sandbox keys from ZaloPay Developer Portal)
ZALOPAY_APP_ID=2554
ZALOPAY_KEY1=your-zalopay-key1
ZALOPAY_KEY2=your-zalopay-key2
ZALOPAY_REDIRECT_URL=https://your-app.replit.app/payment/result
ZALOPAY_IPN_URL=https://your-app.replit.app/api/wallet/deposit/zalopay-ipn

# ─── Email ────────────────────────────────────────────────────────────────────
# Replit Mail (auto-configured in Replit environment)
# RESEND_API_KEY=re_xxxx  # Alternative if not using Replit Mail

# ─── App URLs ─────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5000
NODE_ENV=development
PORT=3001
